---
import Layout from  "../layouts/Layout.astro"
import ProductCard from "../components/ProductCard.astro";

const endpoint = "https://thdoqgracksozeryynpr.supabase.co/rest/v1/Beer?select=*";

const options = {
  headers: {
    apikey: "sb_publishable_lNBP-QLEhH4Xx-p9mOP2Aw_aaOQC20D",
    Authorization: "Bearer sb_publishable_lNBP-QLEhH4Xx-p9mOP2Aw_aaOQC20D",
  },
};

const res = await fetch(endpoint, options);
const beers = await res.json();

const products = Array.isArray(beers) ? beers.slice(0, 10) : [];
---

<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <title>Produkter</title>
  </head>

  <body>
    <section class="container">
      <div class="tabs">
        <button class="active">Nyheder</button>
        <button>Mest Solgte</button>
      </div>

      <div class="grid">
       {products.map((product) => (
  <ProductCard
    Title={product.Title}
    Variant_Price={product["Variant_Price"]}
    Variant_Compare_At_Price={product["Variant_Compare_At_Price"]}
    Image_Src={product["Image_Src"]}
    link={`/product/${product.Handle}`}
  />
))}
      </div>
    </section>
  </body>
</html>

<style>
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 20px;
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 40px;
  margin-bottom: 30px;
}

.tabs button {
  background: none;
  border: none;
  font-size: 16px;
  cursor: pointer;
  position: relative;
}

.tabs .active::after {
  content: "";
  position: absolute;
  width: 100%;
  height: 2px;
  background: black;
  bottom: -5px;
  left: 0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
}
</style>

