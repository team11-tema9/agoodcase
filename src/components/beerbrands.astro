<style>
  .brands {
    background: #fffefc;
    padding: 4rem 2rem 3.5rem;
    text-align: center;
    overflow: hidden;
  }

  .brands h2 {
    margin-bottom: 2.5rem;
    font-family: "Bricolage Grotesque", sans-serif;
    font-size: 2rem;
    font-weight: 600;
    color: #111;
  }

  .brands-viewport {
    max-width: 1100px;
    margin: 0 auto;
    overflow: hidden;
  }

  .brands-track {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: max-content;
    animation: scrollBrands 45s linear infinite;
  }

  .brands-track img {
    width: 140px;
    height: 100px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .dots {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    gap: 0.4rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d4d4d4;
  }

  .dot.active {
    background: #111;
  }
  .brands-track:hover {
  animation-play-state: paused;
}

  @keyframes scrollBrands {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 1rem));
    }
  }

  @media (max-width: 900px) {
    .brands-track img {
      width: 100px;
      height: 70px;
    }
  }
</style>